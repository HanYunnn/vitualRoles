# 複製這支成 .env，把金鑰填到等號後面：  cp .env.example .env
# 不需要的功能可以留空（對應功能會停用或報錯，不影響其他功能）

# OpenAI —— 配音轉錄(Whisper)、生圖(gpt-image)、乾淨背景 inpaint、優化 prompt、自動 B-roll
# 取得：https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Fish Audio —— TTS 配音（預設 TTS 引擎）
# 取得：https://fish.audio → API
FISH_AUDIO_API_KEY=

# ElevenLabs —— TTS 配音（可選，替代 Fish Audio）
ELEVENLABS_API_KEY=

# Hedra —— 對嘴影片（Avatar / Character-3）
# 取得：https://www.hedra.com
HEDRA_API_KEY=

# Pexels —— B-roll 免費影片素材
# 取得：https://www.pexels.com/api/
PEXELS_API_KEY=

# fal.ai —— 動態背景(Luma/Kling/Wan) + 對嘴(Kling Avatar/OmniHuman) + nano-banana 後備
# 取得：https://fal.ai/dashboard/keys
FAL_KEY=

# Google Gemini —— 直連 nano-banana(Gemini 2.5 Flash Image) 生圖/去背；留空則自動走 fal
# 取得：https://aistudio.google.com/apikey （生圖需開啟 billing）
GEMINI_API_KEY=
